{
  "name": "mcp_text-to-sql",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "npm run dev --workspace @mcp-text-to-sql/web",
    "dev:server": "npm run dev --workspace @mcp-text-to-sql/server",
    "db:migrate": "dotenv -e .env -- sh -c 'psql \"$DATABASE_URL\" -f db/migrations/0001_init.sql'",
    "db:seed": "dotenv -e .env -- sh -c 'psql \"$DATABASE_URL\" -f db/seeds/001_users.sql'",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.0",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.4"
  }
}
